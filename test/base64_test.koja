struct Base64Test
  @test "encodes the RFC 4648 test vectors"
  fn test_encode_vectors -> Result<Bool, String>
    match Base64Test.expect_encode("", "")
      Result.Err(e) -> return Result.Err(e)
      Result.Ok(_) -> ()
    end

    match Base64Test.expect_encode("f", "Zg==")
      Result.Err(e) -> return Result.Err(e)
      Result.Ok(_) -> ()
    end

    match Base64Test.expect_encode("fo", "Zm8=")
      Result.Err(e) -> return Result.Err(e)
      Result.Ok(_) -> ()
    end

    match Base64Test.expect_encode("foo", "Zm9v")
      Result.Err(e) -> return Result.Err(e)
      Result.Ok(_) -> ()
    end

    match Base64Test.expect_encode("foob", "Zm9vYg==")
      Result.Err(e) -> return Result.Err(e)
      Result.Ok(_) -> ()
    end

    match Base64Test.expect_encode("fooba", "Zm9vYmE=")
      Result.Err(e) -> return Result.Err(e)
      Result.Ok(_) -> ()
    end

    Base64Test.expect_encode("foobar", "Zm9vYmFy")
  end

  @test "decodes the RFC 4648 test vectors"
  fn test_decode_vectors -> Result<Bool, String>
    match Base64Test.expect_decode("", "")
      Result.Err(e) -> return Result.Err(e)
      Result.Ok(_) -> ()
    end

    match Base64Test.expect_decode("Zg==", "f")
      Result.Err(e) -> return Result.Err(e)
      Result.Ok(_) -> ()
    end

    match Base64Test.expect_decode("Zm8=", "fo")
      Result.Err(e) -> return Result.Err(e)
      Result.Ok(_) -> ()
    end

    match Base64Test.expect_decode("Zm9v", "foo")
      Result.Err(e) -> return Result.Err(e)
      Result.Ok(_) -> ()
    end

    match Base64Test.expect_decode("Zm9vYg==", "foob")
      Result.Err(e) -> return Result.Err(e)
      Result.Ok(_) -> ()
    end

    match Base64Test.expect_decode("Zm9vYmE=", "fooba")
      Result.Err(e) -> return Result.Err(e)
      Result.Ok(_) -> ()
    end

    Base64Test.expect_decode("Zm9vYmFy", "foobar")
  end

  @test "round-trips arbitrary bytes including 0x00 and 0xFF"
  fn test_binary_round_trip -> Result<Bool, String>
    original = <<0::8>> <> <<255::8>> <> <<128::8>> <> <<7::8>>
    encoded = Base64.encode(original)

    unless encoded == "AP+ABw=="
      return Result.Err("expected `AP+ABw==`, got `#{encoded}`")
    end

    decoded =
      match Base64.decode(encoded)
        Result.Ok(d) -> d
        Result.Err(e) -> return Result.Err("decode failed: " <> e)
      end

    unless decoded.byte_size() == 4
      return Result.Err("expected 4 bytes, got #{decoded.byte_size()}")
    end

    unless Base64Test.byte_at(decoded, 0) == 0
      return Result.Err("byte 0 mismatch")
    end

    unless Base64Test.byte_at(decoded, 1) == 255
      return Result.Err("byte 1 mismatch")
    end

    unless Base64Test.byte_at(decoded, 2) == 128
      return Result.Err("byte 2 mismatch")
    end

    Base64Test.byte_at(decoded, 3) == 7
      ? Result.Ok(true)
      : Result.Err("byte 3 mismatch")
  end

  @test "rejects malformed input"
  fn test_decode_rejects_malformed -> Result<Bool, String>
    match Base64.decode("Zg")
      Result.Ok(_) -> return Result.Err("expected truncated input to fail")
      Result.Err(_) -> ()
    end

    match Base64.decode("Z!==")
      Result.Ok(_) -> return Result.Err("expected invalid character to fail")
      Result.Err(_) -> ()
    end

    match Base64.decode("Zg==Zg==")
      Result.Ok(_) -> Result.Err("expected mid-stream padding to fail")
      Result.Err(_) -> Result.Ok(true)
    end
  end

  priv fn expect_encode(input: String, want: String) -> Result<Bool, String>
    got = Base64.encode(input.to_binary())
    got == want
      ? Result.Ok(true)
      : Result.Err("encode(\"#{input}\"): expected `#{want}`, got `#{got}`")
  end

  priv fn expect_decode(input: String, want: String) -> Result<Bool, String>
    decoded =
      match Base64.decode(input)
        Result.Ok(d) -> d
        Result.Err(e) -> return Result.Err("decode(\"#{input}\") failed: " <> e)
      end

    got =
      match decoded.to_string()
        Result.Ok(s) -> s
        Result.Err(_) ->
          return Result.Err("decode(\"#{input}\") produced invalid UTF-8")
      end

    got == want
      ? Result.Ok(true)
      : Result.Err("decode(\"#{input}\"): expected `#{want}`, got `#{got}`")
  end

  priv fn byte_at(data: Binary, index: Int) -> Int
    match data.at(index)
      Option.Some(b) -> b
      Option.None -> -1
    end
  end
end
