# Integration tests against a live Postgres server. Start it first:
#
# docker compose up -d
#
priv const TEST_DATABASE: String = "koja_test"
priv const TEST_HOST: String = "127.0.0.1"
priv const TEST_PORT: Int = 5434

struct IntegrationTest
  @test "connects with trust auth and runs SELECT"
  fn test_trust_select -> Result<Bool, String>
    conn =
      match IntegrationTest.connect_trust()
        Result.Ok(c) -> c
        Result.Err(e) -> return Result.Err(e)
      end

    outcome = conn.query("SELECT 1 AS one, 'two' AS two")
    _ = outcome.first.close()

    result =
      match outcome.second
        Result.Ok(r) -> r
        Result.Err(e) -> return Result.Err(e.message())
      end

    unless result.tag == "SELECT 1"
      return Result.Err("expected tag `SELECT 1`, got `#{result.tag}`")
    end

    unless result.fields.length() == 2
      return Result.Err("expected 2 fields, got #{result.fields.length()}")
    end

    match IntegrationTest.cell(result, 0, 0)
      Option.Some(value) ->
        unless value == "1"
          return Result.Err("expected `1`, got `#{value}`")
        end

      Option.None ->
        return Result.Err("expected cell (0,0) to be non-NULL")
    end

    match IntegrationTest.cell(result, 0, 1)
      Option.Some(value) ->
        value == "two"
          ? Result.Ok(true)
          : Result.Err("expected `two`, got `#{value}`")

      Option.None ->
        Result.Err("expected cell (0,1) to be non-NULL")
    end
  end

  @test "returns NULL columns as None"
  fn test_null_column -> Result<Bool, String>
    conn =
      match IntegrationTest.connect_trust()
        Result.Ok(c) -> c
        Result.Err(e) -> return Result.Err(e)
      end

    outcome = conn.query("SELECT NULL AS nothing")
    _ = outcome.first.close()

    result =
      match outcome.second
        Result.Ok(r) -> r
        Result.Err(e) -> return Result.Err(e.message())
      end

    match IntegrationTest.cell(result, 0, 0)
      Option.None -> Result.Ok(true)
      Option.Some(value) -> Result.Err("expected NULL, got `#{value}`")
    end
  end

  @test "runs DDL and DML with the right command tags"
  fn test_ddl_and_dml_tags -> Result<Bool, String>
    conn =
      match IntegrationTest.connect_trust()
        Result.Ok(c) -> c
        Result.Err(e) -> return Result.Err(e)
      end

    created = conn.query("CREATE TEMP TABLE driver_test (id INT, label TEXT)")
    conn = created.first

    match IntegrationTest.expect_tag(created.second, "CREATE TABLE")
      Result.Err(e) ->
        _ = conn.close()
        return Result.Err(e)

      Result.Ok(_) ->
        ()
    end

    inserted = conn.query(
      "INSERT INTO driver_test VALUES (7, 'seven'), (8, NULL)",
    )
    conn = inserted.first

    match IntegrationTest.expect_tag(inserted.second, "INSERT 0 2")
      Result.Err(e) ->
        _ = conn.close()
        return Result.Err(e)

      Result.Ok(_) ->
        ()
    end

    selected = conn.query("SELECT label FROM driver_test ORDER BY id")
    _ = selected.first.close()

    result =
      match selected.second
        Result.Ok(r) -> r
        Result.Err(e) -> return Result.Err(e.message())
      end

    unless result.rows.length() == 2
      return Result.Err("expected 2 rows, got #{result.rows.length()}")
    end

    match IntegrationTest.cell(result, 0, 0)
      Option.Some(value) ->
        unless value == "seven"
          return Result.Err("expected `seven`, got `#{value}`")
        end

      Option.None ->
        return Result.Err("expected row 0 to be non-NULL")
    end

    match IntegrationTest.cell(result, 1, 0)
      Option.None -> Result.Ok(true)
      Option.Some(value) -> Result.Err("expected NULL, got `#{value}`")
    end
  end

  @test "surfaces server errors with severity and SQLSTATE"
  fn test_server_error -> Result<Bool, String>
    conn =
      match IntegrationTest.connect_trust()
        Result.Ok(c) -> c
        Result.Err(e) -> return Result.Err(e)
      end

    outcome = conn.query("SELEC 1")
    _ = outcome.first.close()

    match outcome.second
      Result.Ok(_) ->
        Result.Err("expected a syntax error, got a result")

      Result.Err(Error.Server(server_error)) ->
        unless server_error.code == "42601"
          return Result.Err("expected SQLSTATE 42601, got #{server_error.code}")
        end

        server_error.severity == "ERROR"
          ? Result.Ok(true)
          : Result.Err("expected severity ERROR, got #{server_error.severity}")

      Result.Err(e) ->
        Result.Err("expected Error.Server, got: " <> e.message())
    end
  end

  @test "connects with a cleartext password"
  fn test_cleartext_auth -> Result<Bool, String>
    config = Config.new(TEST_HOST, TEST_PORT, "koja_password", TEST_DATABASE)
      .with_password("koja_password_secret")

    IntegrationTest.connect_and_select_user(config, "koja_password")
  end

  @test "connects with SCRAM-SHA-256"
  fn test_scram_auth -> Result<Bool, String>
    config = Config.new(TEST_HOST, TEST_PORT, "koja_scram", TEST_DATABASE)
      .with_password("koja_scram_secret")

    IntegrationTest.connect_and_select_user(config, "koja_scram")
  end

  @test "rejects a wrong SCRAM password"
  fn test_scram_wrong_password -> Result<Bool, String>
    config = Config.new(TEST_HOST, TEST_PORT, "koja_scram", TEST_DATABASE)
      .with_password("wrong")

    match Connection.connect(config)
      Result.Ok(conn) ->
        _ = conn.close()
        Result.Err("expected authentication to fail")

      Result.Err(Error.Server(server_error)) ->
        server_error.code == "28P01"
          ? Result.Ok(true)
          : Result.Err("expected SQLSTATE 28P01, got #{server_error.code}")

      Result.Err(e) ->
        Result.Err("expected a server error, got: " <> e.message())
    end
  end

  @test "fails clearly when a password is needed but missing"
  fn test_missing_password -> Result<Bool, String>
    config = Config.new(TEST_HOST, TEST_PORT, "koja_scram", TEST_DATABASE)

    match Connection.connect(config)
      Result.Ok(conn) ->
        _ = conn.close()
        Result.Err("expected connect to fail without a password")

      Result.Err(Error.AuthenticationFailed(_)) ->
        Result.Ok(true)

      Result.Err(e) ->
        Result.Err("expected AuthenticationFailed, got: " <> e.message())
    end
  end

  @test "executes a parameterized SELECT"
  fn test_execute_select -> Result<Bool, String>
    conn =
      match IntegrationTest.connect_trust()
        Result.Ok(c) -> c
        Result.Err(e) -> return Result.Err(e)
      end

    params: List<Option<String>> = [Option.Some("40"), Option.Some("2")]
    outcome = conn.execute("SELECT $1::int + $2::int AS total", params)
    _ = outcome.first.close()

    result =
      match outcome.second
        Result.Ok(r) -> r
        Result.Err(e) -> return Result.Err(e.message())
      end

    unless result.tag == "SELECT 1"
      return Result.Err("expected tag `SELECT 1`, got `#{result.tag}`")
    end

    match IntegrationTest.cell(result, 0, 0)
      Option.Some(value) ->
        value == "42"
          ? Result.Ok(true)
          : Result.Err("expected `42`, got `#{value}`")

      Option.None ->
        Result.Err("expected total to be non-NULL")
    end
  end

  @test "executes DML with NULL parameters and reads them back"
  fn test_execute_null_param -> Result<Bool, String>
    conn =
      match IntegrationTest.connect_trust()
        Result.Ok(c) -> c
        Result.Err(e) -> return Result.Err(e)
      end

    no_params: List<Option<String>> = List.new()
    created = conn.execute(
      "CREATE TEMP TABLE exec_test (id INT, label TEXT)",
      no_params,
    )
    conn = created.first

    match IntegrationTest.expect_tag(created.second, "CREATE TABLE")
      Result.Err(e) ->
        _ = conn.close()
        return Result.Err(e)

      Result.Ok(_) ->
        ()
    end

    insert_params: List<Option<String>> = [Option.Some("1"), Option.None]
    inserted = conn.execute(
      "INSERT INTO exec_test VALUES ($1::int, $2::text)",
      insert_params,
    )
    conn = inserted.first

    match IntegrationTest.expect_tag(inserted.second, "INSERT 0 1")
      Result.Err(e) ->
        _ = conn.close()
        return Result.Err(e)

      Result.Ok(_) ->
        ()
    end

    select_params: List<Option<String>> = [Option.Some("1")]
    selected = conn.execute(
      "SELECT label FROM exec_test WHERE id = $1::int",
      select_params,
    )
    _ = selected.first.close()

    result =
      match selected.second
        Result.Ok(r) -> r
        Result.Err(e) -> return Result.Err(e.message())
      end

    unless result.rows.length() == 1
      return Result.Err("expected 1 row, got #{result.rows.length()}")
    end

    match IntegrationTest.cell(result, 0, 0)
      Option.None -> Result.Ok(true)
      Option.Some(value) -> Result.Err("expected NULL label, got `#{value}`")
    end
  end

  @test "surfaces server errors from execute"
  fn test_execute_server_error -> Result<Bool, String>
    conn =
      match IntegrationTest.connect_trust()
        Result.Ok(c) -> c
        Result.Err(e) -> return Result.Err(e)
      end

    no_params: List<Option<String>> = List.new()
    outcome = conn.execute("SELECT * FROM missing_table", no_params)
    _ = outcome.first.close()

    match outcome.second
      Result.Ok(_) ->
        Result.Err("expected an error for a missing table")

      Result.Err(Error.Server(server_error)) ->
        server_error.code == "42P01"
          ? Result.Ok(true)
          : Result.Err("expected SQLSTATE 42P01, got #{server_error.code}")

      Result.Err(e) ->
        Result.Err("expected Error.Server, got: " <> e.message())
    end
  end

  priv fn connect_and_select_user(config: Config, want_user: String)
    -> Result<Bool, String>

    conn =
      match Connection.connect(config)
        Result.Ok(c) -> c
        Result.Err(e) ->
          return Result.Err("connect failed (is docker compose up?): " <>
            e.message())
      end

    outcome = conn.query("SELECT current_user")
    _ = outcome.first.close()

    result =
      match outcome.second
        Result.Ok(r) -> r
        Result.Err(e) -> return Result.Err(e.message())
      end

    match IntegrationTest.cell(result, 0, 0)
      Option.Some(value) ->
        value == want_user
          ? Result.Ok(true)
          : Result.Err("expected `#{want_user}`, got `#{value}`")

      Option.None ->
        Result.Err("expected current_user to be non-NULL")
    end
  end

  priv fn connect_trust -> Result<Connection, String>
    config = Config.new(TEST_HOST, TEST_PORT, "koja_trust", TEST_DATABASE)

    match Connection.connect(config)
      Result.Ok(conn) ->
        Result.Ok(conn)

      Result.Err(e) ->
        Result.Err("connect failed (is docker compose up?): " <> e.message())
    end
  end

  priv fn cell(result: QueryResult, row: Int, column: Int) -> Option<String>
    match result.rows.get(row)
      Option.Some(columns) ->
        match columns.get(column)
          Option.Some(value) -> value
          Option.None -> Option.None
        end

      Option.None ->
        Option.None
    end
  end

  priv fn expect_tag(outcome: Result<QueryResult, Error>, want: String)
    -> Result<Bool, String>

    match outcome
      Result.Ok(result) ->
        result.tag == want
          ? Result.Ok(true)
          : Result.Err("expected tag `#{want}`, got `#{result.tag}`")

      Result.Err(e) ->
        Result.Err(e.message())
    end
  end
end
